# ── LLM Provider ──────────────────────────────────────────────────────────
# 可选值: deepseek, qwen, openai（默认 deepseek）
LLM_PROVIDER=deepseek

# ── API Keys（按需填写，未使用的 provider 可留空） ─────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key
QWEN_API_KEY=your-qwen-api-key
OPENAI_API_KEY=your-openai-api-key

# ── Model Override（可选，覆盖 constants/llm.py 中的默认值）────────────
# 示例：DEEPSEEK_MODEL=deepseek-v4-pro
# 示例：QWEN_MODEL=qwen3.6-max-preview
# 示例：OPENAI_MODEL=gpt-4.1
DEEPSEEK_MODEL=
QWEN_MODEL=
OPENAI_MODEL=

# ── Base URL Override（可选，用于代理或自托管兼容 API）─────────────────
# 示例：DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_BASE_URL=
QWEN_BASE_URL=
OPENAI_BASE_URL=

# ── GitHub（可选，不设置有速率限制，仅用于 GitHub Trending 采集） ──────
GITHUB_TOKEN=your-github-token

# ── Thinking 模式 ─────────────────────────────────────────────────────────
# ENABLE_THINKING=true  → 开启思考过程（deepseek/qwen 适用）
# ENABLE_THINKING=false → 关闭思考过程（默认，节省 token）
# 不设置则使用 config/llm.json 中的配置
ENABLE_THINKING=false

# ── extra_body 等细粒度参数 ──────────────────────────────────────────────
# 请在 config/llm.json 中配置 provider 级别的 extra_body 参数
