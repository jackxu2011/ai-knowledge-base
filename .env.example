# ── LLM Provider ──────────────────────────────────────────────────────────
# 可选值: deepseek, qwen, openai（默认 deepseek）
LLM_PROVIDER=deepseek

# ── API Keys（按需填写，未使用的 provider 可留空） ─────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key
QWEN_API_KEY=your-qwen-api-key
OPENAI_API_KEY=your-openai-api-key

# ── GitHub（可选，不设置有速率限制，仅用于 GitHub Trending 采集） ──────
GITHUB_TOKEN=your-github-token

# ── LLM 高级配置 ────────────────────────────────────────────────────────
# Thinking 模式开关（默认 false，关闭 thinking 可大幅节省输出 token）
# ENABLE_THINKING=true  → 开启思考过程（deepseek/qwen 适用）
# ENABLE_THINKING=false → 关闭思考过程（默认）
# 不设置则使用 config/llm.json 中的配置
ENABLE_THINKING=false

# extra_body 等更细粒度的 provider 级别参数请在 config/llm.json 中配置
